# 复制这个文件为 .env，然后填入你自己的值

# 在 https://www.eachlabs.ai 注册后，从 Settings -> API Keys 拿到
EACHLABS_API_KEY=your_api_key_here

# 部署上线后，这里填你的服务对外可访问的完整地址（不要带最后的斜杠）
# 本地用 ngrok 之类工具内网穿透测试时，也填 ngrok 给你的那个 https 地址
# 例如：https://hairstyle-backend.onrender.com
PUBLIC_BASE_URL=http://localhost:3000

# 服务监听的端口，部署平台通常会自动注入 PORT，这里是本地默认值
PORT=3000
